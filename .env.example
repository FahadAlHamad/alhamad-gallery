# ── Database (Vercel Postgres — copy these from Vercel dashboard) ──────────────
# Get these from: Vercel Dashboard → Storage → your database → .env.local tab
DATABASE_URL="postgres://..."
DATABASE_URL_UNPOOLED="postgres://..."

# ── Session secret (any random string, at least 32 characters) ────────────────
SESSION_PASSWORD="change-this-to-a-long-random-string-minimum-32-chars"

# ── Email notifications for contact form (optional) ───────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
CONTACT_EMAIL="admin@alhamadgallery.com"
